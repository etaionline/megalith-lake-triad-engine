, "metadata": {"id": "run_pipeline"}, "outputs": [], "source": ["# Run the triad analysis pipeline\n", "# Adjust the file paths based on what you uploaded\n", "\n", "!python triad_pipeline.py \\\n", "    --hydrolakes data_raw/hydrolakes/HydroLAKES.shp \\\n", "    --megalithic_portal_csv data_raw/megalithic_portal.csv \\\n", "    --osm_geojson data_raw/osm/archaeological_sites.geojson \\\n", "    --unesco_csv data_raw/unesco.csv \\\n", "    --out_dir data_out\n", "\n", "print(\"Pipeline completed!\")"]}, {"cell_type": "markdown", "source": ["## Generate Interactive Map\n", "\n", "Create an interactive map to visualize the results."], "metadata": {"id": "map_section"}}, {"cell_type": "code", "execution_count": null, "metadata": {"id": "create_map"}, "outputs": [], "source": ["# Generate interactive map\n", "!python folium_map.py \\\n", "    --lakes data_out/lakes.geojson \\\n", "    --megaliths data_out/megaliths.geojson \\\n", "    --triads data_out/triads.csv \\\n", "    --out data_out/triad_analysis_map.html\n", "\n", "print(\"Interactive map generated!\")\n", "print(\"File saved as: data_out/triad_analysis_map.html\")"]}, {"cell_type": "markdown", "source": ["## Analyze Results\n", "\n", "Load and examine the analysis results."], "metadata": {"id": "analysis_section"}}, {"cell_type": "code", "execution_count": null, "metadata": {"id": "examine_results"}, "outputs": [], "source": ["import pandas as pd\n", "import geopandas as gpd\n", "\n", "# Load results\n", "triads_df = pd.read_csv('data_out/triads.csv')\n", "lakes_gdf = gpd.read_file('data_out/lakes.geojson')\n", "megaliths_gdf = gpd.read_file('data_out/megaliths.geojson')\n", "\n", "print(\"=== ANALYSIS RESULTS ===\")\n", "print(f\"Total triads found: {len(triads_df)}\")\n", "print(f\"Lakes processed: {len(lakes_gdf)}\")\n", "print(f\"Megalith sites processed: {len(megaliths_gdf)}\")\n", "\n", "print(\"\\n=== SAMPLE TRIADS ===\")\n", "print(triads_df.head())\n", "\n", "# Basic statistics\n", "if len(triads_df) > 0:\n", "    print(\"\\n=== DISTANCE STATISTICS ===\")\n", "    print(f\"Average settlement-to-megalith distance: {triads_df['megalith_settlement_distance_km'].mean():.2f} km\")\n", "    print(f\"Average megalith-to-lake distance: {triads_df['megalith_nearest_lake_dist_km'].mean():.2f} km\")\n", "    \n", "    # Check your hypothesis: larger lakes should be farther from settlements\n", "    if 'megalith_nearest_lake_dist_km' in triads_df.columns:\n", "        print(\"\\n=== HYPOTHESIS TESTING ===\")\n", "        print(\"Testing: Distance increases with potential lake size...\")\n", "        # This is where you'd correlate with actual lake areas\n", "        print(\"Distance distribution:\")\n", "        print(triads_df['megalith_nearest_lake_dist_km'].describe())"]}], {"cell_type": "markdown", "source": ["## Export Results\n", "\n", "Download your analysis results for further investigation."], "metadata": {"id": "export_section"}}, {"cell_type": "code", "execution_count": null, "metadata": {"id": "export_data"}, "outputs": [], "source": ["# Export results for download\n", "!zip -r megalith_lake_analysis.zip data_out/\n", "\n", "# Download the results\n", "from google.colab import files\n", "files.download('megalith_lake_analysis.zip')\n", "\n", "print(\"Results exported and ready for download!\")"]}]}